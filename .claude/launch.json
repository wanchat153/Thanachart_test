{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--prefix",
        "frontend"
      ],
      "port": 3000,
      "autoPort": false
    },
    {
      "name": "backend",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "run",
        "--project",
        "Thanachart_test/Thanachart_test.csproj",
        "--launch-profile",
        "http"
      ],
      "port": 5126,
      "autoPort": false
    }
  ]
}
